# Discord bot credentials
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

# External APIs
RAWG_API_KEY=your_rawg_api_key_here

# Optional Discord channel configuration
WELCOME_CHANNEL_ID=
STREAM_ALERT_CHANNEL_ID=
STREAM_LOG_CHANNEL_ID=
BOT_LOG_CHANNEL_ID=

# Optional features
ENABLE_WELCOME_NICKNAME=false

# Future music-player foundation
# Leave disabled until a voice/audio backend is added.
ENABLE_MUSIC=false
MUSIC_MAX_QUEUE_SIZE=50
MUSIC_IDLE_DISCONNECT_MS=300000
